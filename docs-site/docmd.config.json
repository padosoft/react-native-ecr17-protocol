{
  "title": "react-native-ecr17-protocol",
  "description": "React Native Nitro module for Italian ECR17 POS terminal integration over LAN.",
  "url": "https://doc.react-native-ecr17-protocol.padosoft.com",
  "src": "docs",
  "out": "_site",
  "base": "/",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "enabled": true,
      "collapsible": true,
      "defaultCollapsed": false,
      "position": "left"
    },
    "footer": {
      "style": "minimal",
      "content": "MIT licensed documentation for padosoft/react-native-ecr17-protocol.",
      "branding": true
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true,
        "sponsor": null
      }
    },
    "menubar": {
      "enabled": true,
      "position": "top",
      "left": [
        {
          "title": "Docs",
          "path": "/"
        },
        {
          "title": "API",
          "path": "/reference/api"
        }
      ],
      "right": [
        {
          "title": "GitHub",
          "path": "https://github.com/padosoft/react-native-ecr17-protocol",
          "external": true
        }
      ]
    }
  },
  "footer": {
    "style": "minimal",
    "content": "© padosoft. Independent ECR17 interoperability documentation.",
    "branding": true
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true,
    "primaryColor": "#0d9488",
    "customCss": [
      "assets/custom.css"
    ]
  },
  "copyCode": true,
  "pageNavigation": true,
  "minify": true,
  "navigation": [
    {
      "title": "Overview",
