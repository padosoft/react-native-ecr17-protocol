  "plugins": {
    "search": {
      "semantic": true,
      "model": "Xenova/all-MiniLM-L6-v2",
      "include": [
        "**/*.md"
      ],
      "exclude": [
        "**/.git/**",
        "**/node_modules/**"
      ],
      "showConfidence": true,
      "showFilters": true,
      "indexDir": ".docmd-search"
    },
    "git": {
      "repo": "https://github.com/padosoft/react-native-ecr17-protocol",
      "branch": "main",
      "editLink": true,
      "lastUpdated": true,
      "commitHistory": true,
      "maxCommits": 5,
      "dateFormat": "relative"
    },
    "seo": {
      "titleTemplate": "%s | react-native-ecr17-protocol",
      "description": "React Native Nitro module for Italian ECR17 POS terminal integration over LAN."
    },
    "sitemap": {
      "url": "https://doc.react-native-ecr17-protocol.padosoft.com"
    },
    "mermaid": {
      "theme": "default"
    },
    "math": {
      "katex": {}
    },
    "llms": {
      "enabled": true
    },
    "analytics": false
  },
  "favicon": "assets/favicon.svg"
}
