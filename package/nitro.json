{
	"$schema": "https://nitro.margelo.com/nitro.schema.json",
	"cxxNamespace": ["ecr17"],
	"ios": {
		"iosModuleName": "Ecr17"
	},
	"android": {
		"androidNamespace": ["ecr17"],
		"androidCxxLibName": "Ecr17"
	},
	"autolinking": {
		"Ecr17Client": {
			"all": {
				"language": "c++",
				"implementationClassName": "HybridEcr17Client"
			}
		}
	},
	"ignorePaths": ["**/node_modules"]
}
