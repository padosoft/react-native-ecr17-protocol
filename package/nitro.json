{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "ecr17"
  ],
  "ios": {
    "iosModuleName": "Ecr17"
  },
  "android": {
    "androidNamespace": [
      "ecr17"
    ],
    "androidCxxLibName": "Ecr17"
  },
  "autolinking": {
    "Ecr17": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridEcr17"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}